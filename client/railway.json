{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "npm install && npm run build",
    "watchPatterns": ["src/**"]
  },
  "deploy": {
    "startCommand": "npx serve -s dist -l tcp://0.0.0.0:$PORT",
    "restartPolicyType": "always",
    "healthcheckPath": "/"
  }
}
